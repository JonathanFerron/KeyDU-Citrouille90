CompileFlags:
  Remove:
    - -mmcu=*
    - -DF_CPU=*
    - -fshort-enums
    - -mrelax
  Add:
    - -I/usr/lib/avr/include
    - -I/usr/lib/gcc/avr/14.3.0/include
    - -D__AVR_AVR64DU32__
    - -DF_CPU=24000000UL
    - -D_SFR_ASM_COMPAT
    - -D__AVR_ARCH__=102
    - -D__SFR_OFFSET=0x00
    - -D__AVR__=1
    - -D__AVR_XMEGA__=1
    - -D__AVR_MEGA__=1
    - -D__AVR_HAVE_FLMAP__=1
    - -D__AVR_SFR_OFFSET__=0x0
    - -D__AVR_HAVE_JMP_CALL__=1
    - -D__AVR_HAVE_MOVW__=1
    - -D__AVR_HAVE_MUL__=1
